    "bcryptjs": "^2.4.3",
    "better-auth": "^1.5.6",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "kysely": "^0.28.14",
    "multer": "^2.0.2",
    "mysql2": "^3.17.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
